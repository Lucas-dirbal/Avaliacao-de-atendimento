{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/lucas",
      "dest": "/public/lucas.html"
    },
    {
      "src": "/nicolas",
      "dest": "/public/nicolas.html"
    },
    {
      "src": "/leandro",
      "dest": "/public/leandro.html"
    },
    {
      "src": "/pedro",
      "dest": "/public/pedro.html"
    },
    {
      "src": "/willian",
      "dest": "/public/willian.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
